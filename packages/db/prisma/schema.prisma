// Threadly DB schema — fashion-first marketplace + per-shop storefronts.
//
// Conventions:
// - IDs: cuid2 (URL-safe, short, sortable)
// - Money: Int minor units (VND has no decimals; for USD store cents). Currency stored as code.
// - Multi-tenant: every seller-owned row has `storeId` FK.
// - Slugs unique globally for Store; unique per-store for Product.
// - JSON columns kept narrow — use Prisma JSON for shapes typed in @threadly/types.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================================================================
// AUTH / USERS
// =====================================================================

enum UserRole {
  BUYER
  SELLER
  ADMIN
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  displayName  String
  avatarUrl    String?
  role         UserRole @default(BUYER)
  emailVerifiedAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  accounts        Account[]
  sessions        Session[]
  ownedStores     Store[]          @relation("StoreOwner")
  carts           Cart[]
  orders          Order[]
  addresses       Address[]
  wishlistItems   WishlistItem[]
  follows         StoreFollower[]
  productReviews  ProductReview[]

  @@index([role])
}

/// OAuth provider linkage (Auth.js compatible shape).
model Account {
  id                String  @id @default(cuid())
  userId            String
  provider          String
  providerAccountId String
  refreshToken      String? @db.Text
  accessToken       String? @db.Text
  expiresAt         Int?
  tokenType         String?
  scope             String?
  idToken           String? @db.Text

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  sessionToken String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Address {
  id         String   @id @default(cuid())
  userId     String
  fullName   String
  phone      String
  line1      String
  line2      String?
  ward       String?
  district   String?
  city       String
  country    String   @db.VarChar(2)
  postalCode String?
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// =====================================================================
// STORE / STOREFRONT
// =====================================================================

enum StoreStatus {
  DRAFT
  ACTIVE
  SUSPENDED
  CLOSED
}

enum StoreCategory {
  STREETWEAR
  DESIGNER
  VINTAGE
  HANDMADE
  ACCESSORIES
  SHOES
  FORMAL
  ATHLEISURE
  KIDS
  OTHER
}

model Store {
  id        String        @id @default(cuid())
  slug      String        @unique
  name      String
  bio       String?       @db.VarChar(280)
  category  StoreCategory @default(OTHER)
  status    StoreStatus   @default(DRAFT)
  ownerId   String

  /// ThemeConfig — see @threadly/types `themeConfigSchema`
  theme        Json
  /// Denormalized for marketplace listings
  productCount Int     @default(0)
  followerCount Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner    User           @relation("StoreOwner", fields: [ownerId], references: [id])
  products Product[]
  orders   Order[]
  followers StoreFollower[]

  @@index([ownerId])
  @@index([status, category])
}

model StoreFollower {
  storeId   String
  userId    String
  followedAt DateTime @default(now())

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([storeId, userId])
  @@index([userId])
}

// =====================================================================
// CATALOG
// =====================================================================

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

model Product {
  id           String        @id @default(cuid())
  storeId      String
  slug         String
  title        String
  description  String        @db.Text
  status       ProductStatus @default(DRAFT)

  /// FashionDetails — see @threadly/types `fashionDetailsSchema`
  details      Json

  /// String[] of tags (lowercased)
  tags         String[]      @default([])

  /// Denormalized — lowest variant price; minor units
  priceFromAmount   Int
  priceFromCurrency String  @default("VND") @db.VarChar(3)

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  store    Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  images   ProductImage[]
  variants Variant[]
  reviews  ProductReview[]
  wishlistedBy WishlistItem[]

  @@unique([storeId, slug])
  @@index([storeId, status])
  @@index([status, createdAt])
  @@index([tags])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  url       String
  alt       String?
  position  Int     @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, position])
}

model Variant {
  id              String  @id @default(cuid())
  productId       String
  sku             String
  priceAmount     Int
  priceCurrency   String  @default("VND") @db.VarChar(3)
  compareAtAmount Int?
  stock           Int     @default(0)

  /// VariantAttributes — see @threadly/types `variantAttributesSchema`
  attributes      Json

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  cartLines  CartLine[]
  orderLines OrderLine[]

  @@unique([productId, sku])
  @@index([productId])
}

model ProductReview {
  id        String   @id @default(cuid())
  productId String
  userId    String
  rating    Int      // 1-5
  body      String?  @db.Text
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([productId, userId])
  @@index([productId, createdAt])
}

model WishlistItem {
  userId    String
  productId String
  addedAt   DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([userId, productId])
  @@index([userId, addedAt])
}

// =====================================================================
// CART / ORDER
// =====================================================================

model Cart {
  id        String   @id @default(cuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  lines CartLine[]
}

model CartLine {
  id        String @id @default(cuid())
  cartId    String
  variantId String
  quantity  Int

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variant Variant @relation(fields: [variantId], references: [id])

  @@unique([cartId, variantId])
  @@index([cartId])
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  CONFIRMED
  PACKED
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  STRIPE
  VNPAY
  MOMO
  COD
}

model Order {
  id             String        @id @default(cuid())
  number         String        @unique
  buyerId        String
  storeId        String
  status         OrderStatus   @default(PENDING_PAYMENT)
  paymentMethod  PaymentMethod
  subtotalAmount Int
  shippingAmount Int           @default(0)
  totalAmount    Int
  currency       String        @default("VND") @db.VarChar(3)

  /// ShippingAddress snapshot at time of order
  shippingAddress Json

  placedAt  DateTime @default(now())
  updatedAt DateTime @updatedAt

  buyer User  @relation(fields: [buyerId], references: [id])
  store Store @relation(fields: [storeId], references: [id])

  lines OrderLine[]

  @@index([buyerId, placedAt])
  @@index([storeId, placedAt])
  @@index([status])
}

model OrderLine {
  id            String @id @default(cuid())
  orderId       String
  variantId     String
  productTitle  String
  variantLabel  String
  quantity      Int
  unitAmount    Int
  lineAmount    Int

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant Variant @relation(fields: [variantId], references: [id])

  @@index([orderId])
}
