# Build context is monorepo root.

# Deps + build output (rebuilt inside the image)
**/node_modules
**/dist
**/.next
**/.turbo
**/coverage

# Env (NEXT_PUBLIC_* baked via build-args; server-side env at runtime)
.env
.env.*
!.env.example

# VCS / editor
.git
.gitignore
.gitattributes
.github
.vscode
.idea
.DS_Store

# Docker artifacts
**/Dockerfile
**/.dockerignore
docker-compose*.yml

# Logs + tmp
*.log
**/*.log
**/.docker-data

# Tests
**/__tests__
**/*.test.ts
**/*.test.tsx
**/*.spec.ts

# Docs
README.md
**/*.md
