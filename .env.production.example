# Production env — copy to .env.production and fill in.
# NEVER commit .env.production.
#
# Generate strong secrets:
#   openssl rand -base64 48   # JWT_SECRET, AUTH_SECRET
#   openssl rand -base64 32   # MEILISEARCH_KEY, POSTGRES_PASSWORD

# Database
POSTGRES_PASSWORD=replace-me

# Auth secrets
JWT_SECRET=replace-me
AUTH_SECRET=replace-me

# Search
MEILISEARCH_KEY=replace-me

# Public URLs (baked into web build — change requires rebuild)
PUBLIC_API_URL=https://api.threadly.example
PUBLIC_APP_URL=https://threadly.example

# Storage (Cloudflare R2)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=threadly-media
R2_PUBLIC_URL=https://media.threadly.example

# Payments (only if you wired the corresponding adapter)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
